---
---

<section id="access" class="bg-sky-light py-20 px-4" aria-labelledby="access-heading">
  <div class="max-w-6xl mx-auto observe-fade">
    <!-- Section Heading -->
    <div class="text-center mb-12">
      <p class="font-accent text-blue text-2xl mb-2">Access</p>
      <h2 id="access-heading" class="font-heading text-3xl md:text-4xl font-bold text-navy">教室へのアクセス</h2>
    </div>

    <!-- Two Column Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Left: Google Map -->
      <div class="observe-fade">
        <iframe
          src="https://maps.google.com/maps?q=静岡県磐田市水堀160&output=embed"
          class="w-full h-80 md:h-full min-h-[320px] rounded-2xl border-0"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="ハットくんのスクラッチプログラミング教室の地図"
        ></iframe>
      </div>

      <!-- Right: Info -->
      <div class="observe-fade">
        <div class="bg-white rounded-2xl shadow-md p-6 space-y-5">
          <!-- Address -->
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">📍</span>
            <div>
              <p class="font-heading text-navy font-bold text-sm mb-1">住所</p>
              <p class="font-body text-slate">〒438-0085 静岡県磐田市水堀160番地</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">📞</span>
            <div>
              <p class="font-heading text-navy font-bold text-sm mb-1">電話</p>
              <a href="tel:09065823585" class="text-blue hover:text-blue-dark font-body transition-colors duration-200">090-6582-3585</a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">✉️</span>
            <div>
              <p class="font-heading text-navy font-bold text-sm mb-1">メール</p>
              <a href="mailto:hattchi23@gmail.com" class="text-blue hover:text-blue-dark font-body break-all transition-colors duration-200">hattchi23@gmail.com</a>
            </div>
          </div>

          <!-- Divider -->
          <hr class="border-sky" />

          <!-- Business Hours -->
          <div>
            <h3 class="font-heading text-navy font-bold text-lg mb-3">レッスン時間</h3>
            <div class="bg-sky-light rounded-xl p-4">
              <p class="font-body text-navy font-medium text-lg mb-1">10:00〜19:00</p>
              <p class="font-body text-slate text-sm">日曜・月曜 定休</p>
            </div>
            <p class="text-slate text-xs mt-3">※記載時間外もご相談に応じます</p>
          </div>

          <!-- Access Info -->
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">🚗</span>
            <div>
              <p class="font-heading text-navy font-bold text-sm mb-1">アクセス</p>
              <p class="font-body text-slate">磐田バイパス豊田東ICより車で3分</p>
            </div>
          </div>

          <!-- Parking -->
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">🅿️</span>
            <div>
              <p class="font-heading text-navy font-bold text-sm mb-1">駐車場</p>
              <p class="font-body text-slate">あり</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
