---
---

<section id="contact" class="gradient-bg-dark py-20 px-4" aria-labelledby="contact-heading">
  <div class="max-w-4xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-12 observe-fade">
      <p class="font-accent text-blue-light text-2xl mb-2">Contact</p>
      <h2 id="contact-heading" class="font-heading text-3xl md:text-4xl font-bold text-white">お問い合わせ</h2>
      <p class="text-gray mt-4 font-body text-lg">体験レッスンのお申し込み・ご質問は下記フォームからどうぞ。<br class="hidden sm:inline" />24時間以内にご返信いたします。</p>
    </div>

    <!-- Step Flow -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12 observe-fade">
      <div class="text-center text-white">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-2">
          <span class="font-heading font-bold text-lg">1</span>
        </div>
        <p class="text-sm font-heading font-medium">フォーム送信</p>
        <p class="text-xs text-gray mt-1">下記フォームから</p>
      </div>
      <div class="text-center text-white">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-2">
          <span class="font-heading font-bold text-lg">2</span>
        </div>
        <p class="text-sm font-heading font-medium">確認メール</p>
        <p class="text-xs text-gray mt-1">折り返しご連絡</p>
      </div>
      <div class="text-center text-white">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-2">
          <span class="font-heading font-bold text-lg">3</span>
        </div>
        <p class="text-sm font-heading font-medium">日程調整</p>
        <p class="text-xs text-gray mt-1">ご都合の良い日時</p>
      </div>
      <div class="text-center text-white">
        <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-2">
          <span class="font-heading font-bold text-lg">4</span>
        </div>
        <p class="text-sm font-heading font-medium">体験レッスン</p>
        <p class="text-xs text-gray mt-1">実際にScratchを体験</p>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="observe-fade bg-white rounded-2xl shadow-lg p-6 md:p-10 mb-10">
      <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
        <!-- 氏名 -->
        <div>
          <label for="name" class="block font-heading text-navy font-bold text-sm mb-2">
            氏名 <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="山田 太郎"
            class="w-full px-4 py-3 rounded-xl border border-sky bg-sky-light/50 font-body text-navy placeholder:text-gray focus:outline-none focus:ring-2 focus:ring-blue focus:border-transparent transition-all duration-200"
          />
        </div>

        <!-- メールアドレス -->
        <div>
          <label for="email" class="block font-heading text-navy font-bold text-sm mb-2">
            メールアドレス <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="example@email.com"
            class="w-full px-4 py-3 rounded-xl border border-sky bg-sky-light/50 font-body text-navy placeholder:text-gray focus:outline-none focus:ring-2 focus:ring-blue focus:border-transparent transition-all duration-200"
          />
        </div>

        <!-- お子さまの学年 -->
        <div>
          <label for="grade" class="block font-heading text-navy font-bold text-sm mb-2">
            お子さまの学年
          </label>
          <select
            id="grade"
            name="grade"
            class="w-full px-4 py-3 rounded-xl border border-sky bg-sky-light/50 font-body text-navy focus:outline-none focus:ring-2 focus:ring-blue focus:border-transparent transition-all duration-200"
          >
            <option value="">選択してください</option>
            <option value="小学1年生">小学1年生</option>
            <option value="小学2年生">小学2年生</option>
            <option value="小学3年生">小学3年生</option>
            <option value="小学4年生">小学4年生</option>
            <option value="小学5年生">小学5年生</option>
            <option value="小学6年生">小学6年生</option>
            <option value="その他">その他</option>
          </select>
        </div>

        <!-- 題名 -->
        <div>
          <label for="subject" class="block font-heading text-navy font-bold text-sm mb-2">
            題名
          </label>
          <input
            type="text"
            id="subject"
            name="subject"
            placeholder="体験レッスンについて"
            class="w-full px-4 py-3 rounded-xl border border-sky bg-sky-light/50 font-body text-navy placeholder:text-gray focus:outline-none focus:ring-2 focus:ring-blue focus:border-transparent transition-all duration-200"
          />
        </div>

        <!-- メッセージ -->
        <div>
          <label for="message" class="block font-heading text-navy font-bold text-sm mb-2">
            メッセージ <span class="text-red-500">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="お気軽にメッセージをお書きください"
            class="w-full px-4 py-3 rounded-xl border border-sky bg-sky-light/50 font-body text-navy placeholder:text-gray focus:outline-none focus:ring-2 focus:ring-blue focus:border-transparent transition-all duration-200 resize-vertical"
          ></textarea>
        </div>

        <!-- Submit Button -->
        <div class="text-center">
          <button
            type="submit"
            class="gradient-bg text-white font-heading font-bold px-10 py-4 rounded-full text-lg hover:shadow-lg hover:scale-105 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-blue focus:ring-offset-2"
          >
            送信する
          </button>
        </div>
      </form>
    </div>

    <!-- Alternative Contact Methods -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 observe-fade">
      <a href="tel:09065823585" class="bg-white/10 text-white rounded-xl p-5 hover:bg-white/20 transition-all duration-200 text-center group">
        <span class="text-2xl block mb-2" aria-hidden="true">📞</span>
        <p class="font-heading text-sm font-medium mb-1">電話</p>
        <p class="text-white/80 font-body text-xs">090-6582-3585</p>
      </a>
      <a href="mailto:hattchi23@gmail.com" class="bg-white/10 text-white rounded-xl p-5 hover:bg-white/20 transition-all duration-200 text-center group">
        <span class="text-2xl block mb-2" aria-hidden="true">✉️</span>
        <p class="font-heading text-sm font-medium mb-1">メール</p>
        <p class="text-white/80 font-body text-xs">hattchi23@gmail.com</p>
      </a>
      <a href="https://www.instagram.com/hattokun1/" target="_blank" rel="noopener noreferrer" class="bg-white/10 text-white rounded-xl p-5 hover:bg-white/20 transition-all duration-200 text-center group">
        <span class="text-2xl block mb-2" aria-hidden="true">📷</span>
        <p class="font-heading text-sm font-medium mb-1">Instagram</p>
        <p class="text-white/80 font-body text-xs">@hattokun1</p>
      </a>
    </div>
  </div>
</section>
