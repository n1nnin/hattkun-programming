---
---

<section id="features" class="py-20 px-4 bg-sky-light">
  <div class="max-w-6xl mx-auto">
    <!-- Section Heading -->
    <div class="text-center mb-12 observe-fade">
      <p class="font-accent text-blue text-2xl mb-2">Features</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy">プログラミング教室の特徴</h2>
    </div>

    <!-- Feature Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      <!-- Card 1: 論理的思考力 -->
      <div class="observe-fade bg-white rounded-2xl shadow-md p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-transparent hover:border-blue/20">
        <div class="w-14 h-14 rounded-xl gradient-bg flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-navy mb-3">論理的思考力</h3>
        <p class="font-body text-slate leading-relaxed">
          プログラミングを通じて「どうすれば目標を達成できるか」を考える力を育てます。ブロックを組み合わせて順序立てて考える習慣が、学校の勉強にも活きてきます。
        </p>
      </div>

      <!-- Card 2: 創造力・想像力 -->
      <div class="observe-fade bg-white rounded-2xl shadow-md p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-transparent hover:border-purple/20">
        <div class="w-14 h-14 rounded-xl bg-purple flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-navy mb-3">創造力・想像力</h3>
        <p class="font-body text-slate leading-relaxed">
          ゲームやアニメーションの制作を通じて、自由な発想力を伸ばします。「こんなものを作りたい！」というアイデアを自分の手で形にする体験ができます。
        </p>
      </div>

      <!-- Card 3: 問題解決能力 -->
      <div class="observe-fade bg-white rounded-2xl shadow-md p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-transparent hover:border-cyan/20">
        <div class="w-14 h-14 rounded-xl bg-cyan flex items-center justify-center mb-6">
          <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.491 48.491 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.401.604-.401.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.959.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl font-bold text-navy mb-3">問題解決能力</h3>
        <p class="font-body text-slate leading-relaxed">
          うまくいかない時に諦めず、自ら解決する姿勢が身につきます。「なぜ動かないんだろう？」と試行錯誤する経験が、粘り強さを育てます。
        </p>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="observe-fade bg-white rounded-2xl shadow-md p-8 md:p-10">
      <div class="flex flex-col sm:flex-row justify-center items-center gap-8 sm:gap-16">
        <div class="text-center">
          <p class="font-heading text-4xl md:text-5xl font-bold gradient-text">270<span class="text-2xl">件</span></p>
          <p class="text-sm text-slate mt-2">特許出願の講師が指導</p>
        </div>
        <div class="hidden sm:block w-px h-14 bg-blue/20" aria-hidden="true"></div>
        <div class="text-center">
          <p class="font-heading text-4xl md:text-5xl font-bold gradient-text">20<span class="text-2xl">作品+</span></p>
          <p class="text-sm text-slate mt-2">Scratch公開作品</p>
        </div>
        <div class="hidden sm:block w-px h-14 bg-blue/20" aria-hidden="true"></div>
        <div class="text-center">
          <p class="font-heading text-4xl md:text-5xl font-bold gradient-text">小3<span class="text-2xl">〜</span></p>
          <p class="text-sm text-slate mt-2">対象年齢</p>
        </div>
      </div>
    </div>

    <!-- Mini CTA -->
    <div class="text-center mt-12 observe-fade">
      <a href="#contact" class="inline-block text-blue hover:text-blue-dark font-heading font-medium transition-colors duration-300">
        まずは体験してみませんか？ →
      </a>
    </div>
  </div>
</section>
