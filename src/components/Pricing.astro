---
---

<section id="pricing" class="py-20 px-4 bg-sky-light">
  <div class="max-w-6xl mx-auto">
    <!-- Section Heading -->
    <div class="text-center mb-16 observe-fade">
      <p class="font-accent text-blue text-2xl mb-2">Pricing</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-navy">料金のご案内</h2>
      <p class="font-body text-slate mt-4 max-w-xl mx-auto">
        お友達と一緒に受けるとお得！人数が多いほどお安くなるグループ割引制度があります。
      </p>
    </div>

    <!-- Trial Lesson Card (Highlighted) -->
    <div class="observe-fade max-w-md mx-auto mb-12">
      <div class="relative bg-white rounded-2xl shadow-lg overflow-hidden border-2 border-orange/40 hover:shadow-xl transition-shadow duration-300">
        <!-- Badge -->
        <div class="absolute top-0 right-0 bg-orange text-white text-xs font-bold font-heading px-3 py-1 rounded-bl-lg">
          まずはここから！
        </div>
        <div class="bg-orange text-white px-6 py-5 text-center">
          <h3 class="font-heading text-xl font-bold">体験レッスン</h3>
          <p class="text-sm mt-1 opacity-90">初めての方向け</p>
        </div>
        <div class="p-8 text-center">
          <p class="font-heading text-4xl font-bold text-navy mb-1">
            <span class="text-orange">¥500</span>
          </p>
          <p class="text-sm text-slate font-body">1名 / 30分</p>
          <div class="mt-5">
            <a
              href="#contact"
              class="inline-block bg-orange hover:bg-orange/90 text-white font-heading font-medium rounded-full px-6 py-3 transition-colors duration-300 shadow-md hover:shadow-lg text-sm"
            >
              体験レッスンを申し込む
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Course Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <!-- 入門コース -->
      <div class="observe-fade bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
        <div class="bg-blue text-white px-6 py-5 text-center">
          <h3 class="font-heading text-xl font-bold">入門コース</h3>
          <p class="text-sm mt-1 opacity-90">月3回 / 30分</p>
        </div>
        <div class="p-8">
          <!-- Price Table -->
          <table class="w-full mb-6" role="table">
            <thead>
              <tr class="text-sm text-slate border-b border-sky">
                <th class="font-body font-normal text-left pb-2" scope="col">人数</th>
                <th class="font-body font-normal text-right pb-2" scope="col">月謝（税込）</th>
              </tr>
            </thead>
            <tbody class="font-body text-navy">
              <tr class="border-b border-sky/50">
                <td class="py-3">1人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg">¥7,000</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
              <tr class="border-b border-sky/50">
                <td class="py-3">2人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg">¥6,000</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
              <tr class="border-b border-sky/50">
                <td class="py-3">3人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg">¥5,000</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
              <tr>
                <td class="py-3">4人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg text-blue-dark">¥4,000</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
            </tbody>
          </table>
          <div class="text-sm text-slate font-body border-t border-sky pt-4 space-y-2">
            <p class="font-heading font-bold text-navy text-center mb-2">小学3〜4年生向け</p>
            <ul class="space-y-1 text-xs">
              <li class="flex items-start gap-1.5"><span class="text-blue mt-0.5">✓</span>マウス操作・Scratchの基本を習得</li>
              <li class="flex items-start gap-1.5"><span class="text-blue mt-0.5">✓</span>簡単なアニメーション・ゲーム制作</li>
              <li class="flex items-start gap-1.5"><span class="text-blue mt-0.5">✓</span>順序・繰り返し・条件分岐の考え方</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- 基礎コース -->
      <div class="observe-fade bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
        <div class="bg-purple text-white px-6 py-5 text-center">
          <h3 class="font-heading text-xl font-bold">基礎コース</h3>
          <p class="text-sm mt-1 opacity-90">月3回 / 45分</p>
        </div>
        <div class="p-8">
          <!-- Price Table -->
          <table class="w-full mb-6" role="table">
            <thead>
              <tr class="text-sm text-slate border-b border-sky">
                <th class="font-body font-normal text-left pb-2" scope="col">人数</th>
                <th class="font-body font-normal text-right pb-2" scope="col">月謝（税込）</th>
              </tr>
            </thead>
            <tbody class="font-body text-navy">
              <tr class="border-b border-sky/50">
                <td class="py-3">1人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg">¥9,000</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
              <tr class="border-b border-sky/50">
                <td class="py-3">2人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg">¥7,000</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
              <tr class="border-b border-sky/50">
                <td class="py-3">3人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg">¥5,500</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
              <tr>
                <td class="py-3">4人</td>
                <td class="py-3 text-right">
                  <span class="font-heading font-bold text-lg text-purple-dark">¥4,500</span>
                  <span class="text-sm text-slate">/月</span>
                </td>
              </tr>
            </tbody>
          </table>
          <div class="text-sm text-slate font-body border-t border-sky pt-4 space-y-2">
            <p class="font-heading font-bold text-navy text-center mb-2">小学5〜6年生向け</p>
            <ul class="space-y-1 text-xs">
              <li class="flex items-start gap-1.5"><span class="text-purple mt-0.5">✓</span>オリジナルゲーム・アニメーション制作</li>
              <li class="flex items-start gap-1.5"><span class="text-purple mt-0.5">✓</span>変数・リスト・クローンを活用</li>
              <li class="flex items-start gap-1.5"><span class="text-purple mt-0.5">✓</span>数学×プログラミングにも挑戦</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Group Discount Info Box -->
    <div class="observe-fade bg-white rounded-2xl p-6 md:p-8 shadow-md border border-blue/10">
      <div class="flex items-start gap-4 mb-4">
        <div class="w-10 h-10 rounded-lg gradient-bg flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
          </svg>
        </div>
        <div>
          <h4 class="font-heading font-bold text-navy mb-1">グループ割引でお得に！</h4>
          <p class="font-body text-slate text-sm leading-relaxed">
            お友達やご兄弟と一緒に受講すると、1人あたりの料金がお安くなります。4人グループなら入門コースが<strong class="text-blue-dark">¥4,000/月</strong>から。お気軽にご相談ください。
          </p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12 observe-fade">
      <p class="text-slate font-body mb-4">まずはお気軽にワンコイン体験からどうぞ</p>
      <a
        href="#contact"
        class="inline-block gradient-bg hover:opacity-90 text-white font-heading font-medium rounded-full px-8 py-4 transition-all duration-300 shadow-lg shadow-blue/25 hover:shadow-xl hover:shadow-blue/30 hover:-translate-y-0.5"
      >
        体験レッスンを予約する（¥500 / 30分）
      </a>
    </div>
  </div>
</section>
