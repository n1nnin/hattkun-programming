---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const projects = allPosts
  .filter((post) => post.data.scratchId)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((post) => ({
    id: post.data.scratchId!,
    title: post.data.title,
    grade: post.data.grade ?? '5-6年生',
    slug: post.id,
  }));
---

<section id="gallery" class="bg-sky-light py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 md:mb-16 observe-fade">
      <span class="inline-block font-accent text-2xl text-purple mb-2">Gallery</span>
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold mb-4">
        <span class="gradient-text">作品ギャラリー</span>
      </h2>
      <p class="text-slate text-base md:text-lg max-w-2xl mx-auto">
        お子さまがこんな作品を作れるようになります。遊んでみよう！
      </p>
    </div>

    <!-- Project Grid -->
    <div
      id="gallery-grid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
    >
      {projects.map((project, index) => (
        <div
          class:list={[
            "gallery-card group observe-fade",
            index >= 6 && "gallery-hidden hidden",
          ]}
          data-project-id={project.id}
          data-project-title={project.title}
        >
          <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-sky hover:border-blue-light hover:-translate-y-1">
            <!-- Thumbnail -->
            <div class="relative overflow-hidden">
              <img
                src={`https://cdn2.scratch.mit.edu/get_image/project/${project.id}_480x360.png`}
                alt={`${project.title}のサムネイル`}
                class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
              <!-- Grade Badge -->
              <span
                class:list={[
                  "absolute top-3 left-3 text-xs font-bold px-3 py-1 rounded-full shadow-sm",
                  project.grade === "3-4年生"
                    ? "bg-orange text-white"
                    : "bg-blue text-white",
                ]}
              >
                {project.grade}
              </span>
              <!-- Play Overlay -->
              <div class="absolute inset-0 bg-navy/0 group-hover:bg-navy/30 transition-colors duration-300 flex items-center justify-center">
                <div class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100 transition-all duration-300 shadow-lg">
                  <svg class="w-7 h-7 text-blue ml-1" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </div>
            <!-- Card Body -->
            <div class="p-4 md:p-5">
              <h3 class="font-heading text-base md:text-lg font-bold text-navy mb-3 truncate">
                {project.title}
              </h3>
              <button
                class="play-btn w-full gradient-bg text-white text-sm font-bold rounded-full py-2.5 px-4 hover:opacity-90 active:scale-[0.97] transition-all duration-200 flex items-center justify-center gap-2"
                data-project-id={project.id}
                data-project-title={project.title}
                aria-label={`${project.title}を遊ぶ`}
              >
                <span>遊んでみる</span>
                <span aria-hidden="true">&#9654;</span>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 observe-fade">
      <a href="#contact" class="inline-block text-purple hover:text-purple-dark font-heading font-medium transition-colors duration-300">
        お子さまも作品づくりに挑戦してみませんか？ → 体験レッスンを申し込む
      </a>
    </div>

    <!-- Show More Button -->
    <div class="text-center mt-6 observe-fade">
      <button
        id="show-more-btn"
        class="inline-flex items-center gap-2 bg-white text-navy font-heading font-bold text-base rounded-full px-8 py-3.5 shadow-md hover:shadow-lg border-2 border-blue/20 hover:border-blue transition-all duration-300 hover:-translate-y-0.5"
        aria-expanded="false"
      >
        <span id="show-more-label">もっと見る</span>
        <svg id="show-more-icon" class="w-5 h-5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Modal -->
  <div
    id="scratch-modal"
    class="fixed inset-0 z-[100] hidden items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-navy/80 backdrop-blur-sm"></div>
    <!-- Modal Content -->
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-xl overflow-hidden animate-fade-in">
      <!-- Modal Header -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-sky">
        <h3 id="modal-title" class="font-heading text-lg font-bold text-navy truncate pr-4"></h3>
        <button
          id="modal-close"
          class="shrink-0 w-9 h-9 rounded-full bg-gray-light hover:bg-sky flex items-center justify-center transition-colors duration-200"
          aria-label="閉じる"
        >
          <svg class="w-5 h-5 text-slate" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <!-- Iframe Container -->
      <div class="relative w-full" style="padding-bottom: 82.89%;">
        <iframe
          id="modal-iframe"
          class="absolute inset-0 w-full h-full"
          src=""
          allowfullscreen
          title="Scratchプロジェクト"
        ></iframe>
      </div>
      <!-- Modal Footer -->
      <div class="px-5 py-3 bg-sky-light border-t border-sky text-center">
        <a
          id="modal-scratch-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-blue hover:text-blue-dark font-medium transition-colors duration-200 inline-flex items-center gap-1"
        >
          Scratchで開く
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // Show More / Show Less toggle
  const showMoreBtn = document.getElementById("show-more-btn");
  const showMoreLabel = document.getElementById("show-more-label");
  const showMoreIcon = document.getElementById("show-more-icon");
  const hiddenCards = document.querySelectorAll(".gallery-hidden");

  let expanded = false;

  showMoreBtn?.addEventListener("click", () => {
    expanded = !expanded;
    hiddenCards.forEach((card) => {
      card.classList.toggle("hidden", !expanded);
    });
    if (showMoreLabel) {
      showMoreLabel.textContent = expanded ? "閉じる" : "もっと見る";
    }
    showMoreIcon?.classList.toggle("rotate-180", expanded);
    showMoreBtn?.setAttribute("aria-expanded", String(expanded));
  });

  // Modal
  const modal = document.getElementById("scratch-modal");
  const modalBackdrop = document.getElementById("modal-backdrop");
  const modalClose = document.getElementById("modal-close");
  const modalTitle = document.getElementById("modal-title");
  const modalIframe = document.getElementById("modal-iframe") as HTMLIFrameElement | null;
  const modalScratchLink = document.getElementById("modal-scratch-link") as HTMLAnchorElement | null;

  function openModal(projectId: string, title: string) {
    if (!modal || !modalIframe || !modalTitle || !modalScratchLink) return;
    modalTitle.textContent = title;
    modalIframe.src = `https://scratch.mit.edu/projects/${projectId}/embed`;
    modalScratchLink.href = `https://scratch.mit.edu/projects/${projectId}/`;
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    document.body.style.overflow = "hidden";
    modalClose?.focus();
  }

  function closeModal() {
    if (!modal || !modalIframe) return;
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    modalIframe.src = "";
    document.body.style.overflow = "";
  }

  // Play button click handlers
  document.querySelectorAll<HTMLButtonElement>(".play-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.projectId;
      const title = btn.dataset.projectTitle;
      if (id && title) openModal(id, title);
    });
  });

  // Thumbnail click handlers
  document.querySelectorAll<HTMLElement>(".gallery-card").forEach((card) => {
    const thumbnail = card.querySelector(".relative.overflow-hidden");
    thumbnail?.addEventListener("click", () => {
      const id = card.dataset.projectId;
      const title = card.dataset.projectTitle;
      if (id && title) openModal(id, title);
    });
    // Add pointer cursor to thumbnail
    if (thumbnail instanceof HTMLElement) {
      thumbnail.style.cursor = "pointer";
    }
  });

  // Close modal
  modalClose?.addEventListener("click", closeModal);
  modalBackdrop?.addEventListener("click", closeModal);

  // Close modal on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal?.classList.contains("hidden")) {
      closeModal();
    }
  });
</script>
